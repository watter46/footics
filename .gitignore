!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# wxt (extensions)
.wxt/
.output/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
.mcp_settings.json

# debug / logs
*.log
*_log.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ide settings
.vscode/
.idea/
*.swp
*.swo

