{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "target": "ES2017",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"],
      "~/*": ["./*"]
    }
  },
  "include": [".wxt/wxt.d.ts", "**/*", "../src/**/*"],
  "exclude": ["node_modules"]
}
